<?xml version="1.0" encoding="utf-8"?>
<COLLADA xmlns="http://www.collada.org/2005/11/COLLADASchema" version="1.4.1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <asset>
    <contributor>
      <author>Blender User</author>
      <authoring_tool>Blender 3.0.0 commit date:2021-12-02, commit time:18:35, hash:f1cca3055776</authoring_tool>
    </contributor>
    <created>2026-03-31T18:04:22</created>
    <modified>2026-03-31T18:04:22</modified>
    <unit name="meter" meter="1"/>
    <up_axis>Z_UP</up_axis>
  </asset>
  <library_effects>
    <effect id="cave_rock-effect">
      <profile_COMMON>
        <newparam sid="cave_stone_png-surface">
          <surface type="2D">
            <init_from>cave_stone_png</init_from>
          </surface>
        </newparam>
        <newparam sid="cave_stone_png-sampler">
          <sampler2D>
            <source>cave_stone_png-surface</source>
          </sampler2D>
        </newparam>
        <technique sid="common">
          <lambert>
            <emission>
              <color sid="emission">0 0 0 1</color>
            </emission>
            <diffuse>
              <texture texture="cave_stone_png-sampler" texcoord="UVMap"/>
            </diffuse>
            <index_of_refraction>
              <float sid="ior">1.45</float>
            </index_of_refraction>
          </lambert>
        </technique>
      </profile_COMMON>
    </effect>
  </library_effects>
  <library_images>
    <image id="cave_stone_png" name="cave_stone_png">
      <init_from>textures/omwdg/cave_stone.png</init_from>
    </image>
  </library_images>
  <library_materials>
    <material id="cave_rock-material" name="cave_rock">
      <instance_effect url="#cave_rock-effect"/>
    </material>
  </library_materials>
  <library_geometries>
    <geometry id="Plane_009-mesh" name="Plane.009">
      <mesh>
        <source id="Plane_009-mesh-positions">
          <float_array id="Plane_009-mesh-positions-array" count="12">-128 -128 256 128 -128 256 -128 128 256 128 128 256</float_array>
          <technique_common>
            <accessor source="#Plane_009-mesh-positions-array" count="4" stride="3">
              <param name="X" type="float"/>
              <param name="Y" type="float"/>
              <param name="Z" type="float"/>
            </accessor>
          </technique_common>
        </source>
        <source id="Plane_009-mesh-normals">
          <float_array id="Plane_009-mesh-normals-array" count="3">0 0 -1</float_array>
          <technique_common>
            <accessor source="#Plane_009-mesh-normals-array" count="1" stride="3">
              <param name="X" type="float"/>
              <param name="Y" type="float"/>
              <param name="Z" type="float"/>
            </accessor>
          </technique_common>
        </source>
        <source id="Plane_009-mesh-map-0">
          <float_array id="Plane_009-mesh-map-0-array" count="12">0.001983642 0.001983642 0.4980164 0.4980164 0.001983642 0.4980164 0.001983642 0.001983642 0.4980164 0.001983642 0.4980164 0.4980164</float_array>
          <technique_common>
            <accessor source="#Plane_009-mesh-map-0-array" count="6" stride="2">
              <param name="S" type="float"/>
              <param name="T" type="float"/>
            </accessor>
          </technique_common>
        </source>
        <vertices id="Plane_009-mesh-vertices">
          <input semantic="POSITION" source="#Plane_009-mesh-positions"/>
        </vertices>
        <triangles material="cave_rock-material" count="2">
          <input semantic="VERTEX" source="#Plane_009-mesh-vertices" offset="0"/>
          <input semantic="NORMAL" source="#Plane_009-mesh-normals" offset="1"/>
          <input semantic="TEXCOORD" source="#Plane_009-mesh-map-0" offset="2" set="0"/>
          <p>2 0 0 1 0 1 0 0 2 2 0 3 3 0 4 1 0 5</p>
        </triangles>
      </mesh>
    </geometry>
    <geometry id="Plane_008-mesh" name="Plane.008">
      <mesh>
        <source id="Plane_008-mesh-positions">
          <float_array id="Plane_008-mesh-positions-array" count="12">-128 -128 0 128 -128 0 -128 128 0 128 128 0</float_array>
          <technique_common>

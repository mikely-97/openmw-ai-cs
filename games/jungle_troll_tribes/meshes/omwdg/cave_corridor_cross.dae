          <float_array id="Plane_008-mesh-normals-array" count="3">0 0 1</float_array>
          <technique_common>
            <accessor source="#Plane_008-mesh-normals-array" count="1" stride="3">
              <param name="X" type="float"/>
              <param name="Y" type="float"/>
              <param name="Z" type="float"/>
            </accessor>
          </technique_common>
        </source>
        <source id="Plane_008-mesh-map-0">
          <float_array id="Plane_008-mesh-map-0-array" count="12">0.001983642 0.9980164 0.4980164 0.5019837 0.4980164 0.9980164 0.001983642 0.9980164 0.001983642 0.5019837 0.4980164 0.5019837</float_array>
          <technique_common>

  <library_effects>
    <effect id="cave_rock-effect">
      <profile_COMMON>
        <newparam sid="cave_stone-surface">
          <surface type="2D">
            <init_from>textures/omwdg/cave_stone.png</init_from>
          </surface>
        </newparam>
        <newparam sid="cave_stone-sampler">
          <sampler2D>
            <source>cave_stone-surface</source>
          </sampler2D>
        </newparam>
        <technique sid="common">
          <lambert>
            <emission>
              <color sid="emission">0 0 0 1</color>
            </emission>
            <diffuse>
              <texture texture="cave_stone-sampler" texcoord="UVMap"/>
            </diffuse>
            <index_of_refraction>
              <float sid="ior">1.45</float>
            </index_of_refraction>
          </lambert>
        </technique>
      </profile_COMMON>
    </effect>
  </library_effects>
  <library_images>
    <image id="cave_stone" name="cave_stone">
      <init_from>textures/omwdg/cave_stone.png</init_from>
    </image>
  </library_images>
  <library_materials>
    <material id="cave_rock-material" name="cave_rock">
      <instance_effect url="#cave_rock-effect"/>
    </material>
  </library_materials>
